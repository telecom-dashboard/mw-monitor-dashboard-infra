variable "aws_region" {
  description = "AWS region for IAM resources"
  type        = string
  default     = "ap-southeast-1"
}

variable "github_org" {
  description = "GitHub organization or username"
  type        = string
  default     = "heinzawhtoo"
}

variable "github_repo" {
  description = "GitHub repository name"
  type        = string
  default     = "terraform-aws-ecs-multi-env-platform"
}

variable "github_branch" {
  description = "GitHub branch allowed to assume the role"
  type        = string
  default     = "main"
}

variable "infra_github_org" {
  description = "GitHub organization or username trusted for the business repo IAM roles"
  type        = string
  default     = "telecom-dashboard"
}

variable "infra_github_repo" {
  description = "GitHub repository trusted for the business repo IAM roles"
  type        = string
  default     = "mw-monitor-dashboard-infra"
}

variable "infra_github_branch" {
  description = "GitHub branch allowed to assume the business repo IAM roles"
  type        = string
  default     = "main"
}

variable "business_app_github_org" {
  description = "GitHub organization or username trusted for the future business app deploy roles"
  type        = string
  default     = "telecom-dashboard"
}

variable "business_app_github_repo" {
  description = "GitHub repository trusted for the future business app deploy roles"
  type        = string
  default     = "mw-dashboard-app"
}

variable "business_app_github_branch" {
  description = "GitHub branch allowed to assume the future business app deploy roles"
  type        = string
  default     = "main"
}

variable "aws_project_resource_prefix" {
  description = "AWS naming prefix used by the business repo dev and prod resources"
  type        = string
  default     = "nwmon"
}

variable "dev_role_name" {
  description = "IAM role name for Terraform dev CI"
  type        = string
  default     = "github-actions-terraform-dev"
}

variable "enable_legacy_terraform_dev_role" {
  description = "Whether to manage the legacy Terraform dev CI role in this repo"
  type        = bool
  default     = false
}

variable "prod_role_name" {
  description = "IAM role name for Terraform prod CI"
  type        = string
  default     = "github-actions-terraform-prod"
}

variable "enable_legacy_terraform_prod_role" {
  description = "Whether to manage the legacy Terraform prod CI role in this repo"
  type        = bool
  default     = false
}

variable "tf_state_bucket_name" {
  description = "S3 bucket name for Terraform remote state"
  type        = string
}

variable "app_dev_role_name" {
  description = "IAM role name for GitHub Actions dev app image build/deploy"
  type        = string
  default     = "github-actions-app-dev"
}

variable "enable_legacy_app_dev_role" {
  description = "Whether to manage the legacy dev app deploy role in this repo"
  type        = bool
  default     = false
}

variable "app_prod_role_name" {
  description = "IAM role name for GitHub Actions prod app image build/deploy"
  type        = string
  default     = "github-actions-app-prod"
}

variable "enable_legacy_app_prod_role" {
  description = "Whether to manage the legacy prod app deploy role in this repo"
  type        = bool
  default     = false
}

variable "mvp_app_deploy_role_name" {
  description = "IAM role name for GitHub Actions MVP app deploy from telecom-dashboard/mw-dashboard-app"
  type        = string
  default     = "github-actions-mvp-app-deploy"
}

variable "mvp_app_github_org" {
  description = "GitHub organization or username trusted for the MVP app deploy role"
  type        = string
  default     = "telecom-dashboard"
}

variable "mvp_app_github_repo" {
  description = "GitHub repository trusted for the MVP app deploy role"
  type        = string
  default     = "mw-dashboard-app"
}

variable "mvp_app_github_branch" {
  description = "GitHub branch allowed to assume the MVP app deploy role"
  type        = string
  default     = "main"
}

variable "mvp_app_github_environment" {
  description = "Optional GitHub Environment allowed to assume the MVP app deploy role"
  type        = string
  default     = "mvp"
}

variable "mvp_assets_bucket_name" {
  description = "MVP assets bucket name used for release artifact uploads"
  type        = string
}

variable "mvp_deploy_target_tag_key" {
  description = "EC2 tag key used to target the MVP app host for SSM Run Command"
  type        = string
  default     = "DeployTarget"
}

variable "mvp_deploy_target_tag_value" {
  description = "EC2 tag value used to target the MVP app host for SSM Run Command"
  type        = string
  default     = "nw-monitor-dashboard-mvp-app-host"
}

variable "mvp_releases_prefix" {
  description = "S3 prefix within the MVP assets bucket used for release artifacts"
  type        = string
  default     = "releases"
}

variable "business_terraform_dev_role_name" {
  description = "IAM role name for business repo Terraform dev CI"
  type        = string
  default     = "github-actions-nwmon-terraform-dev"
}

variable "business_terraform_prod_role_name" {
  description = "IAM role name for business repo Terraform prod CI"
  type        = string
  default     = "github-actions-nwmon-terraform-prod"
}

variable "business_app_dev_role_name" {
  description = "IAM role name for business repo app dev image build/deploy"
  type        = string
  default     = "github-actions-nwmon-app-dev"
}

variable "business_app_prod_role_name" {
  description = "IAM role name for business repo app prod image build/deploy"
  type        = string
  default     = "github-actions-nwmon-app-prod"
}
